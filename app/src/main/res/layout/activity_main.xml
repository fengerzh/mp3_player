<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="#F5F6FA">

    <!-- Header: gradient background with title + folder button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_header_gradient"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <!-- Top row: icon + title + folder button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Small blue circle with music icon -->
            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_music_note"
                android:background="@drawable/bg_album_circle"
                android:scaleType="center"
                android:padding="6dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MP3播放器"
                    android:textSize="20sp"
                    android:textColor="#1A1A2E"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/folderPathText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="本地音乐播放"
                    android:textSize="13sp"
                    android:textColor="#8888A0" />
            </LinearLayout>

            <Button
                android:id="@+id/pickFolderBtn"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="选择文件夹"
                android:textSize="13sp"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_folder_button"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:drawableStart="@drawable/ic_folder"
                android:drawablePadding="6dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Album art area: large blue circle -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp">

        <ImageView
            android:id="@+id/albumArt"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_album_circle"
            android:scaleType="center"
            android:src="@drawable/ic_music_note"
            android:padding="50dp"
            android:elevation="8dp" />
    </FrameLayout>

    <!-- Now playing section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="正在播放"
            android:textSize="13sp"
            android:textColor="#8888A0"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/nowPlayingText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="未选择文件夹"
            android:textSize="18sp"
            android:textColor="#1A1A2E"
            android:textStyle="bold"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="middle"
            android:layout_marginBottom="8dp" />

        <!-- Time display -->
        <TextView
            android:id="@+id/timeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0:00/0:00"
            android:textSize="12sp"
            android:textColor="#8888A0"
            android:layout_marginBottom="4dp" />

        <!-- SeekBar -->
        <SeekBar
            android:id="@+id/seekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:progressTint="#2A6DF7"
            android:progressBackgroundTint="#D0D0D0"
            android:thumbTint="#2A6DF7"
            android:layout_marginBottom="16dp" />
    </LinearLayout>

    <!-- Control buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="12dp">

        <ImageButton
            android:id="@+id/prevBtn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_prev"
            android:background="@drawable/bg_small_button"
            android:elevation="4dp"
            android:contentDescription="上一个"
            android:layout_marginEnd="24dp" />

        <ImageButton
            android:id="@+id/playPauseBtn"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_play"
            android:background="@drawable/bg_play_button"
            android:elevation="6dp"
            android:contentDescription="播放/暂停"
            android:scaleType="center" />

        <ImageButton
            android:id="@+id/nextBtn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_next"
            android:background="@drawable/bg_small_button"
            android:elevation="4dp"
            android:contentDescription="下一个"
            android:layout_marginStart="24dp" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="8dp" />

    <!-- Playlist header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="播放列表"
            android:textSize="15sp"
            android:textColor="#1A1A2E"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/trackCountText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="12sp"
            android:textColor="#8888A0" />
    </LinearLayout>

    <!-- Track list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/trackList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:clipToPadding="false" />

</LinearLayout>
